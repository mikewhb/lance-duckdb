# name: test/sql/float16_widening.test
# description: Float16 (FloatingPoint(HALF)) columns are transparently widened to Float32 on read, including inside struct / list / fixed-size-list.
# group: [sql]

# Fixture: test/data/float16_fixture.lance — regenerate with
# test/scripts/gen_float16_fixture.py (requires pylance + pyarrow).

require lance

statement ok
ATTACH 'test/data' AS ns (TYPE LANCE);

# --- Schema: every HALF occurrence surfaces as FLOAT --------------------------

query TTTTTT
SELECT
  typeof(id),
  typeof(half_scalar),
  typeof(half_vec),
  typeof(half_list),
  typeof(half_struct),
  typeof(half_in_list)
FROM ns.main.float16_fixture LIMIT 1;
----
BIGINT	FLOAT	FLOAT[3]	FLOAT[]	STRUCT(half FLOAT, f32 FLOAT)	STRUCT(h FLOAT)[]

# --- Scalar ------------------------------------------------------------------

query II
SELECT id, half_scalar FROM ns.main.float16_fixture ORDER BY id;
----
0	1.5
1	-2.25
2	3.0
3	0.0
4	65504.0

# --- FixedSizeList<HALF> -----------------------------------------------------

query II
SELECT id, half_vec FROM ns.main.float16_fixture ORDER BY id;
----
0	[0.5, 1.5, 2.5]
1	[-1.0, -2.0, -3.0]
2	[10.0, 20.0, 30.0]
3	[0.125, 0.25, 0.5]
4	[100.0, 200.0, 300.0]

# --- Variable-size List<HALF> ------------------------------------------------

query II
SELECT id, half_list FROM ns.main.float16_fixture ORDER BY id;
----
0	[1.0, 2.0]
1	[3.0]
2	[]
3	[-1.0, -2.0, -3.0]
4	[0.0]

# --- Struct<HALF, FLOAT>: widening happens element-wise inside the struct ----

query II
SELECT id, half_struct FROM ns.main.float16_fixture ORDER BY id;
----
0	{'half': 1.5, 'f32': 10.0}
1	{'half': -2.25, 'f32': 20.0}
2	{'half': 3.0, 'f32': 30.0}
3	{'half': 0.0, 'f32': 40.0}
4	{'half': 65504.0, 'f32': 50.0}

# Struct field projection exercises the nested ArrowToDuckDB path.
query II
SELECT id, half_struct.half FROM ns.main.float16_fixture ORDER BY id;
----
0	1.5
1	-2.25
2	3.0
3	0.0
4	65504.0

# --- List<Struct<HALF>>: struct-inside-list ----------------------------------

query II
SELECT id, half_in_list FROM ns.main.float16_fixture ORDER BY id;
----
0	[{'h': 1.0}]
1	[{'h': 2.0}, {'h': 3.0}]
2	[]
3	[{'h': 4.0}, {'h': 5.0}]
4	[{'h': 6.0}]

# Map<Utf8, Float16> is covered at the schema-conversion layer in the
# lance-spark Scala test — Lance's Rust writer does not yet encode that
# shape, so it cannot be round-tripped through a sqllogic fixture.

# --- Pushdown paths ----------------------------------------------------------

# Exec path (filter pushdown) goes through a different batch loader but the
# same conversion hook.
query II
SELECT id, half_scalar FROM ns.main.float16_fixture WHERE id = 2;
----
2	3.0

# Projection-only scan: verifies single-column widening.
query I
SELECT half_scalar FROM ns.main.float16_fixture WHERE half_scalar > 0 ORDER BY id;
----
1.5
3.0
65504.0

# --- Write-path guard --------------------------------------------------------

# The catalog widens HALF to FLOAT so SELECT works, but writes would silently
# widen the on-disk storage. INSERT/UPDATE/MERGE must refuse until narrowing
# on write is implemented.

statement error
INSERT INTO ns.main.float16_fixture
VALUES (99, 1.0, [1.0, 2.0, 3.0], [1.0], {'half': 1.0, 'f32': 1.0}, []);
----
Arrow types DuckDB cannot represent

statement error
UPDATE ns.main.float16_fixture SET half_scalar = 0 WHERE id = 0;
----
Arrow types DuckDB cannot represent
