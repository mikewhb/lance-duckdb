# ============================================================
# Port of: geometry/st_disjoint.test
# NOTE: Original test uses ST_Boundary(GEOMETRYCOLLECTION EMPTY) which returns NULL geometry.
#       Lance WKB roundtrip for NULL geometry is a known limitation, so we test with
#       non-NULL geometries that are disjoint/non-disjoint instead.
# ============================================================

statement ok
CREATE TABLE disjoint_src (id int, geom geometry);

statement ok
INSERT INTO disjoint_src (id, geom) VALUES
    (0, ST_GeomFromText('POINT(0 0)')),
    (1, ST_GeomFromText('POINT(100 100)')),
    (2, ST_GeomFromText('POLYGON((0 0, 1 0, 1 1, 0 1, 0 0))'));

statement ok
COPY disjoint_src TO '__TEST_DIR__/disjoint.lance' (FORMAT lance);

# Point(0,0) is NOT disjoint from Polygon (it's on the boundary)
query I
SELECT ST_Disjoint(a1.geom, a2.geom) FROM '__TEST_DIR__/disjoint.lance' as a1, '__TEST_DIR__/disjoint.lance' as a2 WHERE a1.id = 0 and a2.id = 2;
----
false

# Point(100,100) IS disjoint from Polygon
query I
SELECT ST_Disjoint(a1.geom, a2.geom) FROM '__TEST_DIR__/disjoint.lance' as a1, '__TEST_DIR__/disjoint.lance' as a2 WHERE a1.id = 1 and a2.id = 2;
----
true

