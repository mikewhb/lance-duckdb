# name: test/sql/lance.test
# description: Test the lance extension
# group: [sql]

require lance

# Basic extension loading test
query I
SELECT 1
----
1

# Test that lance_scan can read a local dataset root
statement ok
SELECT * FROM lance_scan('test/data/test_data.lance') LIMIT 1

# LIMIT/OFFSET pushdown correctness
query I
SELECT count(*) FROM (SELECT * FROM 'test/data/test_data.lance' LIMIT 2);
----
2

query I
SELECT count(*) FROM (SELECT * FROM 'test/data/test_data.lance' LIMIT 2 OFFSET 1);
----
2

# Explain output includes LIMIT/OFFSET diagnostics
query II
EXPLAIN (FORMAT JSON) SELECT * FROM 'test/data/test_data.lance' LIMIT 2 OFFSET 1;
----
physical_plan	<REGEX>:[\s\S]*"Lance Limit Offset Pushdown": "true"[\s\S]*

query II
EXPLAIN (FORMAT JSON) SELECT * FROM 'test/data/test_data.lance' LIMIT 2 OFFSET 1;
----
physical_plan	<REGEX>:[\s\S]*"Lance Limit": "2"[\s\S]*"Lance Offset": "1"[\s\S]*

query II
EXPLAIN (ANALYZE, FORMAT JSON) SELECT * FROM 'test/data/test_data.lance' LIMIT 2 OFFSET 1;
----
analyzed_plan	<REGEX>:[\s\S]*"Lance Scan Mode": "dataset"[\s\S]*

# TABLESAMPLE SYSTEM (%): sampling pushdown diagnostics
query II
EXPLAIN (FORMAT JSON) SELECT * FROM 'test/data/test_data.lance' TABLESAMPLE SYSTEM (10 PERCENT);
----
physical_plan	<REGEX>:[\s\S]*"Lance Sampling Pushdown": "true"[\s\S]*

query II
EXPLAIN (ANALYZE, FORMAT JSON) SELECT * FROM 'test/data/test_data.lance' TABLESAMPLE SYSTEM (10 PERCENT);
----
analyzed_plan	<REGEX>:[\s\S]*"Lance Scan Mode": "dataset"[\s\S]*

statement ok
SELECT count(*) FROM 'test/data/test_data.lance' TABLESAMPLE SYSTEM (100 PERCENT);

# Baseline: materialize once and evaluate filters in DuckDB
statement ok
CREATE TEMP TABLE baseline AS SELECT * FROM 'test/data/test_data.lance'

# Test parallel scan + filter pushdown correctness
statement ok
PRAGMA threads=4

query I
SELECT count(*) FROM 'test/data/test_data.lance' WHERE age > 30
----
3

query I
SELECT count(*) FROM 'test/data/test_data.lance' WHERE name IN ('Alice', 'Eve')
----
2

query I
SELECT count(*) FROM 'test/data/test_data.lance'
----
5

query I
SELECT count(*) FROM 'test/data/test_data.lance' WHERE age > 30 AND score < 90
----
2

# Test complex filter forms
query I
SELECT count(*) FROM 'test/data/test_data.lance' WHERE age > 30 OR score < 90
----
4

query I
SELECT count(*) FROM 'test/data/test_data.lance' WHERE NOT (age > 30)
----
2

query I
SELECT count(*) FROM 'test/data/test_data.lance' WHERE age BETWEEN 26 AND 40
----
3

query I
SELECT count(*) FROM 'test/data/test_data.lance' WHERE name NOT IN ('Alice', 'Eve')
----
3

# Projection + filter correctness (also exercises projection pushdown path)
query T
SELECT name FROM 'test/data/test_data.lance' WHERE age > 30 ORDER BY name
----
Charlie
David
Eve

# Equivalence: baseline table (DuckDB evaluation) matches expected results
query I
SELECT count(*) FROM baseline WHERE age > 30
----
3

query I
SELECT count(*) FROM baseline WHERE name IN ('Alice', 'Eve')
----
2

query I
SELECT count(*) FROM baseline WHERE age > 30 AND score < 90
----
2

# Explain output includes Lance-specific diagnostics (bind-time and runtime)
query II
EXPLAIN (FORMAT JSON) SELECT count(*) FROM 'test/data/test_data.lance' WHERE age > 30;
----
physical_plan	<REGEX>:[\s\S]*"Lance Path": "test/data/test_data\.lance"[\s\S]*

query II
EXPLAIN (FORMAT JSON) SELECT count(*) FROM 'test/data/test_data.lance' WHERE age > 30;
----
physical_plan	<REGEX>:[\s\S]*"Lance Plan \(Bind\)"[\s\S]*

query II
EXPLAIN (ANALYZE, FORMAT JSON) SELECT count(*) FROM 'test/data/test_data.lance' WHERE age > 30;
----
analyzed_plan	<REGEX>:[\s\S]*"Lance Rows Out"[\s\S]*

query II
EXPLAIN (ANALYZE, FORMAT JSON) SELECT count(*) FROM 'test/data/test_data.lance' WHERE age > 30;
----
analyzed_plan	<REGEX>:[\s\S]*"Lance Plan"[\s\S]*

query I
SELECT count(*) FROM baseline WHERE age > 30 OR score < 90
----
4

query I
SELECT count(*) FROM baseline WHERE NOT (age > 30)
----
2

query I
SELECT count(*) FROM baseline WHERE age BETWEEN 26 AND 40
----
3

query I
SELECT count(*) FROM baseline WHERE name NOT IN ('Alice', 'Eve')
----
3

# Test replacement scan for SELECT * FROM '.../dataset.lance'
statement ok
SELECT * FROM 'test/data/test_data.lance' LIMIT 1

# Test error handling - invalid dataset root
statement error
SELECT * FROM 'dummy_path.lance'
----
IO Error: Failed to open Lance dataset: dummy_path.lance (Lance error: dataset open 'dummy_path.lance':
