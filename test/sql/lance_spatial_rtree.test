# name: test/sql/lance_spatial_rtree.test
# description: Full port of duckdb_spatial RTree test cases to Lance data path.
#              All data storage, index creation, and querying go through Lance,
#              NOT duckdb_spatial's in-memory RTree.
#
# Ported from duckdb_spatial/test/sql/index/:
#   rtree_basic.test, rtree_basic_points.test, rtree_single.test,
#   rtree_empty.test, rtree_projection.test, rtree_multi.test,
#   rtree_pushdown.test, rtree_filter_prune.test, rtree_filter_pullup.test,
#   rtree_filter_pullup_2.test, rtree_basic_data.test_slow
#
# Tests NOT ported (depend on DuckDB in-memory table features):
#   rtree_crud.test (row-level DML), rtree_crud_noreinsert.test,
#   rtree_insert.test_slow, rtree_insert_empty.test,
#   rtree_conflict.test (IF NOT EXISTS syntax),
#   rtree_dump.test (rtree_index_dump internal func),
#   rtree_limits.test (node_capacity params),
#   rtree_block_reclaim.test_slow (DuckDB storage blocks),
#   rtree_persistence*.test (DuckDB .db restart - Lance is inherently persistent)
# group: [lance]

require spatial

require lance

require parquet

# ============================================================
# Port of: rtree_basic.test
# Original: CREATE TABLE -> INSERT -> CREATE INDEX RTREE -> EXPLAIN
# Lance:    COPY TO .lance -> CREATE INDEX RTREE -> lance_rtree_index_scan
# ============================================================

statement ok
CREATE TABLE rtree_basic_src (geom GEOMETRY);

statement ok
INSERT INTO rtree_basic_src VALUES ('POINT(0 0)'::GEOMETRY), ('POINT(40 40)'::GEOMETRY), ('POINT(2 2)'::GEOMETRY);

statement ok
COPY rtree_basic_src TO '__TEST_DIR__/rtree_basic.lance' (FORMAT lance);

statement ok
CREATE INDEX basic_idx ON '__TEST_DIR__/rtree_basic.lance' (geom) USING RTREE;

# Verify index created
query IIIII
SHOW INDEXES ON '__TEST_DIR__/rtree_basic.lance';
----
basic_idx	RTree	geom	3	{}

# Verify query through lance_rtree_index_scan (equivalent to RTREE_INDEX_SCAN)
# st_within(geom, 'POINT(1 2)') => bbox is [1,2,1,2], only POINT(2 2) could be in bbox
# but POINT(2 2) is not within POINT(1 2), so 0 results.
# Using lance_rtree_index_scan with a small bbox around POINT(1 2)
query I
SELECT count(*) FROM lance_rtree_index_scan('__TEST_DIR__/rtree_basic.lance', 'geom', 1.0, 2.0, 1.0, 2.0);
----
0

# Verify all 3 points exist
query I
SELECT count(*) FROM lance_rtree_index_scan('__TEST_DIR__/rtree_basic.lance', 'geom', -1.0, -1.0, 50.0, 50.0);
----
3

statement ok
DROP INDEX basic_idx ON '__TEST_DIR__/rtree_basic.lance';

# ============================================================
# Port of: rtree_basic_points.test
# Original: st_generatepoints 10000 -> count with ST_Within -> CREATE INDEX
#           -> same count (verifies index correctness)
# Lance:    COPY generated points to .lance -> CREATE INDEX -> verify count
# ============================================================

statement ok
CREATE TABLE rtree_points_src AS SELECT point::GEOMETRY as geom
FROM st_generatepoints({min_x: 0, min_y: 0, max_x: 1000, max_y: 1000}::BOX_2D, 10000, 1337);

# Get ground truth count for bbox [450,450]-[650,650]
# Original test expects 390 (with seed 1337, 10000 points)
query I
SELECT count(*) FROM rtree_points_src WHERE ST_Within(geom, ST_MakeEnvelope(450, 450, 650, 650));
----
390

statement ok
COPY rtree_points_src TO '__TEST_DIR__/rtree_basic_points.lance' (FORMAT lance);

statement ok
CREATE INDEX points_idx ON '__TEST_DIR__/rtree_basic_points.lance' (geom) USING RTREE;

# lance_rtree_index_scan uses bbox intersection (not ST_Within),
# so count may differ slightly from ST_Within. Verify with ST_Within on results.
query I
SELECT count(*) FROM lance_rtree_index_scan('__TEST_DIR__/rtree_basic_points.lance', 'geom', 450.0, 450.0, 650.0, 650.0) WHERE ST_Within(geom, ST_MakeEnvelope(450, 450, 650, 650));
----
390

statement ok
DROP INDEX points_idx ON '__TEST_DIR__/rtree_basic_points.lance';

# ============================================================
# Port of: rtree_single.test
