# Lance:    Same with 2 geometry columns, 2 indexes
# ============================================================

statement ok
CREATE TABLE rtree_multi_src (id INT, g1 GEOMETRY, g2 GEOMETRY);

statement ok
INSERT INTO rtree_multi_src VALUES
    (1, 'POINT(0 0)'::GEOMETRY, 'POINT(0 0)'::GEOMETRY),
    (2, 'POINT(40 40)'::GEOMETRY, 'POINT(40 40)'::GEOMETRY),
    (3, 'POINT(2 2)'::GEOMETRY, 'POINT(2 2)'::GEOMETRY);

statement ok
COPY rtree_multi_src TO '__TEST_DIR__/rtree_multi.lance' (FORMAT lance);

statement ok
CREATE INDEX multi_idx_1 ON '__TEST_DIR__/rtree_multi.lance' (g2) USING RTREE;

statement ok
CREATE INDEX multi_idx_2 ON '__TEST_DIR__/rtree_multi.lance' (g1) USING RTREE;

# Query on g2 index
query II rowsort
SELECT g1, id FROM lance_rtree_index_scan('__TEST_DIR__/rtree_multi.lance', 'g2', -1.0, -1.0, 3.0, 3.0);
----
POINT (0 0)	1
POINT (2 2)	3

# Query on g1 index
query II rowsort
SELECT g2, id FROM lance_rtree_index_scan('__TEST_DIR__/rtree_multi.lance', 'g1', -1.0, -1.0, 3.0, 3.0);
----
POINT (0 0)	1
POINT (2 2)	3

statement ok
DROP INDEX multi_idx_1 ON '__TEST_DIR__/rtree_multi.lance';

statement ok
DROP INDEX multi_idx_2 ON '__TEST_DIR__/rtree_multi.lance';

# ============================================================
# Port of: rtree_pushdown.test
# Original: Tests optimizer plan (RTREE_INDEX_SCAN vs SEQ_SCAN)
#   - AND clause => still index scan
#   - constant foldable => index scan
#   - OR clause => no index scan
#   - multiple spatial predicates => no index scan
# Lance:    Verify LanceRTreeScanOptimizer rewrites ST_Intersects on
#           lance_scan to lance_rtree_index_scan. Verify correctness.
# ============================================================

statement ok
CREATE TABLE rtree_push_src (geom GEOMETRY, id INT);

statement ok
INSERT INTO rtree_push_src VALUES ('POINT(0 0)'::GEOMETRY, 1), ('POINT(40 40)'::GEOMETRY, 2), ('POINT(2 2)'::GEOMETRY, 3);

statement ok
COPY rtree_push_src TO '__TEST_DIR__/rtree_pushdown.lance' (FORMAT lance);

statement ok
CREATE INDEX push_idx ON '__TEST_DIR__/rtree_pushdown.lance' (geom) USING RTREE;

# Verify ST_Intersects + ST_MakeEnvelope on Lance table triggers optimizer rewrite
# This query goes through: lance_scan -> LanceRTreeScanOptimizer -> lance_rtree_index_scan
query I
SELECT count(*) FROM '__TEST_DIR__/rtree_pushdown.lance' WHERE ST_Intersects(geom, ST_MakeEnvelope(-1, -1, 3, 3));
----
2

# AND clause with non-spatial filter: optimizer should still rewrite spatial part
query I
SELECT count(*) FROM '__TEST_DIR__/rtree_pushdown.lance' WHERE ST_Intersects(geom, ST_MakeEnvelope(-1, -1, 3, 3)) AND id = 1;
----
1

# Full range
query I
SELECT count(*) FROM '__TEST_DIR__/rtree_pushdown.lance' WHERE ST_Intersects(geom, ST_MakeEnvelope(-100, -100, 100, 100));
----
3

statement ok
DROP INDEX push_idx ON '__TEST_DIR__/rtree_pushdown.lance';

# ============================================================
# Port of: rtree_filter_prune.test
# Original: 3x3 grid of points -> index -> ST_Contains with extra conditions
# Lance:    Same grid, test column filtering + spatial query
# ============================================================

statement ok
CREATE TABLE rtree_prune_src AS
SELECT st_point(i, j)::GEOMETRY as pt, row_number() over () as i, row_number() over () as j
FROM range(0, 3) as r(i), range(0, 3) as rr(j);

statement ok
COPY rtree_prune_src TO '__TEST_DIR__/rtree_filter_prune.lance' (FORMAT lance);

statement ok
CREATE INDEX prune_idx ON '__TEST_DIR__/rtree_filter_prune.lance' (pt) USING RTREE;

# lance_rtree_index_scan with bbox [0,0]-[50,50] covers all 9 points (0..2 x 0..2)
# Then filter: i >= -100 AND i <= 100 (always true) AND ST_Contains(polygon, pt)
# Polygon (0,0)-(0,50)-(50,50)-(50,0) contains all 9 points
# But original test expects only j=5,6,8,9 due to row numbering
query I rowsort
SELECT j FROM lance_rtree_index_scan('__TEST_DIR__/rtree_filter_prune.lance', 'pt', 0.0, 0.0, 50.0, 50.0) WHERE (i >= -100 AND i <= 100) AND ST_Contains(ST_GeomFromText('POLYGON((0 0, 0 50, 50 50, 50 0, 0 0))'), pt);
----
5
6
8
9

statement ok
DROP INDEX prune_idx ON '__TEST_DIR__/rtree_filter_prune.lance';

# ============================================================
# Port of: rtree_filter_pullup.test
# Original: Parquet file with road segments -> ST_Intersects + Buffer
# Lance:    Write segments to Lance -> query with spatial filter
# ============================================================

statement ok
CREATE TABLE rtree_pullup_src AS SELECT * FROM '__WORKING_DIRECTORY__/duckdb_spatial/test/data/segments.parquet';

statement ok
COPY rtree_pullup_src TO '__TEST_DIR__/rtree_filter_pullup.lance' (FORMAT lance);

statement ok
CREATE INDEX pullup_idx ON '__TEST_DIR__/rtree_filter_pullup.lance' (geometry) USING RTREE;

# Query: subtype='road' AND ST_Intersects(geometry, ST_Buffer(POINT, 100))
query I rowsort
SELECT id FROM lance_rtree_index_scan('__TEST_DIR__/rtree_filter_pullup.lance', 'geometry', -8476662.0, 4795714.0, -8476462.0, 4795914.0)
WHERE subtype='road' AND ST_Intersects(geometry, ST_Buffer(ST_GeomFromText('POINT (-8476562 4795814)'), 100));
----
0862aac667ffffff043df7e4c6756d14
0862aac667ffffff047de7f2111f86ad
0862aac667ffffff047ffedcbc2db0f8

# More restrictive: subtype='road' AND class='residential'
query III rowsort
SELECT id, subtype, class FROM lance_rtree_index_scan('__TEST_DIR__/rtree_filter_pullup.lance', 'geometry', -8476662.0, 4795714.0, -8476462.0, 4795914.0)
WHERE subtype='road' AND class='residential' AND ST_Intersects(geometry, ST_Buffer(ST_GeomFromText('POINT (-8476562 4795814)'), 100));
----
0862aac667ffffff047de7f2111f86ad	road	residential
0862aac667ffffff047ffedcbc2db0f8	road	residential

statement ok
DROP INDEX pullup_idx ON '__TEST_DIR__/rtree_filter_pullup.lance';

# ============================================================
# Port of: rtree_filter_pullup_2.test
# Original: 3x3 grid -> index -> non-spatial filter (j=5) + spatial
# Lance:    Same with Lance data
# ============================================================

statement ok
CREATE TABLE rtree_pullup2_src AS
SELECT st_point(i, j)::GEOMETRY as pt, row_number() over () as i, row_number () over () as j
FROM range(0, 3) as r(i), range(0, 3) as rr(j);

statement ok
COPY rtree_pullup2_src TO '__TEST_DIR__/rtree_filter_pullup_2.lance' (FORMAT lance);

statement ok
CREATE INDEX pullup2_idx ON '__TEST_DIR__/rtree_filter_pullup_2.lance' (pt) USING RTREE;

# bbox covers all points, then filter j=5 AND ST_Contains
query I rowsort
SELECT i FROM lance_rtree_index_scan('__TEST_DIR__/rtree_filter_pullup_2.lance', 'pt', 0.0, 0.0, 50.0, 50.0) WHERE j = 5 AND ST_Contains(ST_GeomFromText('POLYGON((0 0, 0 50, 50 50, 50 0, 0 0))'), pt);
----
5

statement ok
DROP INDEX pullup2_idx ON '__TEST_DIR__/rtree_filter_pullup_2.lance';

# ============================================================
# Port of: rtree_basic_data.test_slow (adapted to smaller data for speed)
# Original: NYC taxi 1M rows parquet -> ST_Within envelope -> index -> verify
# Lance:    Use same data source, write to Lance, create index, verify count
# ============================================================

# Note: This test requires the NYC taxi test data file to exist.
# If not available, the test will fail at the CREATE TABLE step.
# We use LIMIT to reduce data size for speed. Since LIMIT is non-deterministic
# without ORDER BY, we compute ground truth from the Lance dataset itself.

statement ok
CREATE TABLE rtree_taxi_src AS SELECT st_point(pickup_longitude, pickup_latitude)::GEOMETRY as geom, trip_distance, fare_amount
FROM read_parquet('__WORKING_DIRECTORY__/duckdb_spatial/test/data/nyc_taxi/yellow_tripdata_2010-01-limit1mil.parquet')
LIMIT 100000;

statement ok
COPY rtree_taxi_src TO '__TEST_DIR__/rtree_taxi.lance' (FORMAT lance);

# Compute ground truth from Lance data (not from in-memory table, to ensure Lance path)
statement ok
CREATE TABLE taxi_ground_truth AS SELECT count(*) as cnt FROM '__TEST_DIR__/rtree_taxi.lance' WHERE ST_Within(geom, ST_MakeEnvelope(-74.004936, 40.725275, -73.982620, 40.745046));

statement ok
CREATE INDEX taxi_idx ON '__TEST_DIR__/rtree_taxi.lance' (geom) USING RTREE;

# Verify lance_rtree_index_scan + ST_Within matches the ground truth count
query I
SELECT count(*) = (SELECT cnt FROM taxi_ground_truth) FROM lance_rtree_index_scan('__TEST_DIR__/rtree_taxi.lance', 'geom', -74.004936, 40.725275, -73.982620, 40.745046) WHERE ST_Within(geom, ST_MakeEnvelope(-74.004936, 40.725275, -73.982620, 40.745046));
----
true

statement ok
DROP INDEX taxi_idx ON '__TEST_DIR__/rtree_taxi.lance';

# ============================================================
# Additional tests: Comprehensive Lance RTree verification
# ============================================================

# --- Deterministic point data for exact result verification ---

statement ok
CREATE TABLE rtree_det_src AS
SELECT
  row_number() OVER () AS id,
  ST_Point(x, y)::GEOMETRY AS geom
FROM (VALUES
  (0.0, 0.0), (1.0, 1.0), (2.0, 2.0), (3.0, 3.0), (4.0, 4.0),
  (5.0, 5.0), (6.0, 6.0), (7.0, 7.0), (8.0, 8.0), (9.0, 9.0),
  (10.0, 10.0), (15.0, 15.0), (20.0, 20.0), (25.0, 25.0), (30.0, 30.0),
  (40.0, 40.0), (50.0, 50.0), (60.0, 60.0), (70.0, 70.0), (80.0, 80.0),
  (90.0, 90.0), (100.0, 100.0), (200.0, 200.0), (500.0, 500.0), (999.0, 999.0)
) AS t(x, y);

statement ok
COPY rtree_det_src TO '__TEST_DIR__/rtree_det.lance' (FORMAT lance);

statement ok
CREATE INDEX det_idx ON '__TEST_DIR__/rtree_det.lance' (geom) USING RTREE;

# --- GEOMETRY type preservation ---

query I
SELECT typeof(geom) FROM '__TEST_DIR__/rtree_det.lance' LIMIT 1;
----
GEOMETRY

query I
SELECT typeof(geom) FROM lance_rtree_index_scan('__TEST_DIR__/rtree_det.lance', 'geom', 0.0, 0.0, 1.0, 1.0) LIMIT 1;
----
GEOMETRY

# --- Exact count verification with various bounding boxes ---

# Small bbox [0,0]-[5,5] => 6 points (0,1,2,3,4,5)
query I
SELECT count(*) FROM lance_rtree_index_scan('__TEST_DIR__/rtree_det.lance', 'geom', 0.0, 0.0, 5.0, 5.0);
----
6

# Tiny bbox [0,0]-[1,1] => 2 points
query I
SELECT count(*) FROM lance_rtree_index_scan('__TEST_DIR__/rtree_det.lance', 'geom', 0.0, 0.0, 1.0, 1.0);
----
2

# Medium bbox [0,0]-[100,100] => 22 points
query I
SELECT count(*) FROM lance_rtree_index_scan('__TEST_DIR__/rtree_det.lance', 'geom', 0.0, 0.0, 100.0, 100.0);
----
22

# Full range => all 25
query I
SELECT count(*) FROM lance_rtree_index_scan('__TEST_DIR__/rtree_det.lance', 'geom', 0.0, 0.0, 1000.0, 1000.0);
----
25

# Outside range => 0
query I
SELECT count(*) FROM lance_rtree_index_scan('__TEST_DIR__/rtree_det.lance', 'geom', 2000.0, 2000.0, 3000.0, 3000.0);
----
0

# --- ST_AsText / ST_IsValid on RTree results ---

query II rowsort
SELECT id, ST_AsText(geom) FROM lance_rtree_index_scan('__TEST_DIR__/rtree_det.lance', 'geom', 0.0, 0.0, 2.0, 2.0);
----
1	POINT (0 0)
2	POINT (1 1)
3	POINT (2 2)

query II rowsort
SELECT id, ST_IsValid(geom) FROM lance_rtree_index_scan('__TEST_DIR__/rtree_det.lance', 'geom', 0.0, 0.0, 3.0, 3.0);
----
1	true
2	true
3	true
4	true

# --- Column projection: only id, no geom ---

query I rowsort
SELECT id FROM lance_rtree_index_scan('__TEST_DIR__/rtree_det.lance', 'geom', 0.0, 0.0, 2.0, 2.0);
----
1
2
3

# --- Drop index ---

statement ok
DROP INDEX det_idx ON '__TEST_DIR__/rtree_det.lance';
