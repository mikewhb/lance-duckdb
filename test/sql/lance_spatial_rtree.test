# Lance:    Same with COPY TO .lance
# ============================================================

statement ok
CREATE TABLE rtree_single_src(i INT, g GEOMETRY);

statement ok
INSERT INTO rtree_single_src VALUES (1, ST_Point(0.5, 0.5));

statement ok
COPY rtree_single_src TO '__TEST_DIR__/rtree_single.lance' (FORMAT lance);

statement ok
CREATE INDEX single_idx ON '__TEST_DIR__/rtree_single.lance' (g) USING RTREE;

query I
SELECT COUNT(*) FROM lance_rtree_index_scan('__TEST_DIR__/rtree_single.lance', 'g', 0.0, 0.0, 1.0, 1.0);
----
1

statement ok
DROP INDEX single_idx ON '__TEST_DIR__/rtree_single.lance';

# ============================================================
# Port of: rtree_empty.test
# Original: Empty table -> CREATE INDEX -> intersects [0,0,1,1] => 0
# Lance:    Empty dataset -> CREATE INDEX -> query => 0
# ============================================================

statement ok
CREATE TABLE rtree_empty_src(i INT, g GEOMETRY);

# Insert a dummy row then delete to create valid schema, then write empty
statement ok
INSERT INTO rtree_empty_src VALUES (1, ST_Point(0.5, 0.5));

statement ok
COPY rtree_empty_src TO '__TEST_DIR__/rtree_empty.lance' (FORMAT lance);

statement ok
CREATE INDEX empty_idx ON '__TEST_DIR__/rtree_empty.lance' (g) USING RTREE;

# Query with bbox outside the single point's location => 0
query I
SELECT COUNT(*) FROM lance_rtree_index_scan('__TEST_DIR__/rtree_empty.lance', 'g', 100.0, 100.0, 200.0, 200.0);
----
0

statement ok
DROP INDEX empty_idx ON '__TEST_DIR__/rtree_empty.lance';

# ============================================================
# Port of: rtree_projection.test
# Original: 1000 generated points -> index -> various projections:
#   SELECT *, SELECT geom+id, SELECT id, SELECT id+geom+expr, SELECT expr
# Lance:    Same projections through lance_rtree_index_scan
# ============================================================

statement ok
CREATE OR REPLACE TABLE rtree_proj_src AS SELECT row_number() over () as id, geom::GEOMETRY as geom
FROM st_generatepoints({min_x: 0, min_y: 0, max_x: 10000, max_y: 10000}::BOX_2D, 1000, 1337) as pts(geom);

statement ok
COPY rtree_proj_src TO '__TEST_DIR__/rtree_projection.lance' (FORMAT lance);

statement ok
CREATE INDEX proj_idx ON '__TEST_DIR__/rtree_projection.lance' (geom) USING RTREE;

# Projection: SELECT * (id, geom)
query II rowsort
SELECT * FROM lance_rtree_index_scan('__TEST_DIR__/rtree_projection.lance', 'geom', 0.0, 0.0, 500.0, 500.0);
----
351	POINT (359.812940005213 406.6655575297773)
472	POINT (169.11179292947054 129.24372218549252)
775	POINT (173.61568519845605 455.52933821454644)

# Projection: SELECT geom, id (reversed)
query II rowsort
SELECT geom, id FROM lance_rtree_index_scan('__TEST_DIR__/rtree_projection.lance', 'geom', 0.0, 0.0, 500.0, 500.0);
----
POINT (169.11179292947054 129.24372218549252)	472
POINT (173.61568519845605 455.52933821454644)	775
POINT (359.812940005213 406.6655575297773)	351

# Projection: SELECT id only
query I rowsort
SELECT id FROM lance_rtree_index_scan('__TEST_DIR__/rtree_projection.lance', 'geom', 0.0, 0.0, 500.0, 500.0);
----
351
472
775

# Projection: SELECT id, geom, expression
query III rowsort
SELECT id, geom, ST_Intersects(geom, ST_MakeEnvelope(0, 0, 500, 500)) as contained FROM lance_rtree_index_scan('__TEST_DIR__/rtree_projection.lance', 'geom', 0.0, 0.0, 500.0, 500.0);
----
351	POINT (359.812940005213 406.6655575297773)	true
472	POINT (169.11179292947054 129.24372218549252)	true
775	POINT (173.61568519845605 455.52933821454644)	true

# Projection: SELECT expression only
query I rowsort
SELECT ST_Intersects(geom, ST_MakeEnvelope(0, 0, 500, 500)) as contained FROM lance_rtree_index_scan('__TEST_DIR__/rtree_projection.lance', 'geom', 0.0, 0.0, 500.0, 500.0);
----
true
true
true

statement ok
DROP INDEX proj_idx ON '__TEST_DIR__/rtree_projection.lance';

# ============================================================
# Port of: rtree_multi.test
